{
  "capabilities": {
    "files": {
      "read": true,
      "edit": true
    },
    "terminal": {
      "execute": false
    },
    "git": {
      "enabled": false
    }
  },
  "tools": {
    "denylist": [
      "clang", "clang++", "cl.exe", "msvc", "msbuild", 
      "ninja", "cmake", "make", "gcc", "g++", "git"
    ]
  },
  "auto_approve": {
    "enabled": false
  },
  "behavior": {
    "use_gitignore": true,
    "prefer_incremental_edits": true,
    "ignore_files": [
      "**/.git/**",
      "**/.vs/**"
    ]
  }
}